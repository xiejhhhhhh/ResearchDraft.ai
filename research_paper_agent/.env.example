# AI API keys. Configure at least one provider for real draft generation.
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
VOLCENGINE_API_KEY=your_volcengine_api_key_here
VOLCENGINE_MODEL_ID=doubao-lite-32k
VOLCENGINE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/chat/completions
ARK_API_KEY=your_ark_api_key_here
WORKER_CLONE_MODEL=your_ark_endpoint_model_id_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Zotero integration. Real values belong only in .env.
ZOTERO_LIBRARY_ID=your_zotero_library_id
ZOTERO_API_KEY=your_zotero_api_key
ZOTERO_LIBRARY_TYPE=user
# Optional for local desktop use. Allows full-text reading from local Zotero PDFs.
# Example Windows path: C:\Users\your_name\Zotero\storage
ZOTERO_LOCAL_STORAGE_DIR=

# External scholarly search. Optional.
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_optional
SERPAPI_API_KEY=your_serpapi_key_optional
EASYSCHOLAR_SECRET_KEY=your_easyscholar_secret_key_optional
# Optional. Used only to locate legal open-access PDFs through Unpaywall.
UNPAYWALL_EMAIL=your_email_for_unpaywall_optional
# Limit temporary open-access PDF downloads per file.
OA_PDF_MAX_MB=25

# Server configuration.
RESEARCH_AGENT_PORT=9000
RESEARCH_AGENT_HOST=0.0.0.0
